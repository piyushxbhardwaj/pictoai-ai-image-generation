# PictoAI Server Configuration Example
# Copy this file to a new file named '.env' in the same folder and fill in your details.

# 1. MongoDB Connection URI
# Local MongoDB: mongodb://localhost:27017/PictoAI
# MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/PictoAI
MONGODB_URI=mongodb://localhost:27017/PictoAI

# 2. JWT Secret Key (used to secure user sessions)
JWT_SECRET=your_jwt_secret_key_here

# 3. Hugging Face API Token (used for stable diffusion image generation fallback)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_hugging_face_token_here

# 4. Clipdrop API Key (optional fallback provider for image generation)
# Get your key from: https://clipdrop.co/apis
CLIPDROP_API=your_clipdrop_api_key_here

# 5. Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# 6. Server Port (default: 3000)
PORT=3000

